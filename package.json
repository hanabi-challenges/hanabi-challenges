{
  "name": "hanabi-challenges",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm -r --if-present lint -- --fix",
    "format": "pnpm -r --if-present format:check",
    "format:fix": "pnpm -r --if-present format",
    "logs:backend": "tail -n 200 var/logs/backend.log || echo 'No backend log file yet.'",
    "logs:backend:follow": "tail -n 50 -f var/logs/backend.log",
    "logs:clean": "rm -f var/logs/backend.log && echo 'Cleared var/logs/backend.log'",
    "dev:env": "bash ./infra/dev/start-dev-env.sh",
    "dev:servers": "concurrently -k -n api,web \"pnpm -C apps/api run dev\" \"pnpm -C apps/web run dev\"",
    "dev": "pnpm run dev:env && pnpm run dev:servers",
    "dev:api": "pnpm -C apps/api run dev",
    "dev:web": "pnpm -C apps/web run dev",
    "dev:backend": "pnpm run dev:api",
    "dev:frontend": "pnpm run dev:web",
    "test": "pnpm -r --if-present test",
    "test:scripts": "node --test tests/unit/tooling/*.test.mjs",
    "test:unit": "pnpm run test:scripts && pnpm -r --if-present test:unit",
    "test:integration": "pnpm -r --if-present test:integration",
    "test:integration:bail": "pnpm -r --if-present test:integration -- --bail=1",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:install": "pnpm exec playwright install chromium",
    "ci:tests": "pnpm run format && pnpm run lint && pnpm run test:unit && pnpm run test:integration && pnpm run build && pnpm run test:e2e",
    "test:api": "pnpm -C apps/api run test",
    "test:api:integration": "pnpm -C apps/api run test:integration",
    "test:web": "pnpm -C apps/web run test",
    "test:backend": "pnpm run test:api",
    "test:backend:integration": "pnpm run test:api:integration",
    "test:frontend": "pnpm run test:web",
    "build": "pnpm run build:shared && pnpm run build:api && pnpm run build:web",
    "build:shared": "pnpm -C packages/shared run build",
    "build:api": "pnpm -C apps/api run build",
    "build:web": "pnpm -C apps/web run build",
    "build:backend": "pnpm run build:api",
    "build:frontend": "pnpm run build:web",
    "prod:start:node": "bash ./infra/prod/start-node.sh",
    "prod:start:docker": "bash ./infra/prod/deploy-compose.sh"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "typescript": "^5.0.0"
  }
}
